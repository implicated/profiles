{
  "title": "AAA Switch Input Source",
  "rules": [
    {
      "description": "Switch Input Source",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_shift",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "parameters": {
            "basic.to_if_alone_timeout_milliseconds": 250,
            "basic.to_if_held_down_threshold_milliseconds": 250
          },
          "to_if_alone": [
            {
              "key_code": "f19"
            }
          ],
          "to_if_held_down": [
            {
              "key_code": "right_shift"
            }
          ]
        }
      ]
    }
  ]
}
